# Copy to .env and fill only the providers you want enabled.
PARALLEL_API_KEY=
BRAVE_API_KEY=
EXA_API_KEY=
TAVILY_API_KEY=
PERPLEXITY_API_KEY=

# Live Task API enrichment is ON by default, guarded by the per-run budget
# below. Set to 0 to force demo enrichment regardless of keys.
CT_SEARCH_LIVE_ENRICHMENT=1

# Per-run spend ceiling (USD). Live steps beyond the primary are skipped, and
# live enrichment falls back to demo, once estimates exceed this.
CT_SEARCH_MAX_RUN_BUDGET_USD=2.00

# Where runs and progress events persist (SQLite). Defaults to output/edna.db.
# CT_SEARCH_DB_PATH=

# Claude key for LLM intent parsing (brief -> job type, source shape, evidence
# risk, freshness, returned fields). Without it the router falls back to
# keyword heuristics, so the app still runs.
ANTHROPIC_API_KEY=
# Override the intent model if needed (default claude-opus-4-8).
CT_SEARCH_INTENT_MODEL=claude-opus-4-8
