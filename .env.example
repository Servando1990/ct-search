# Copy to .env and fill only the providers you want enabled.
PARALLEL_API_KEY=
BRAVE_API_KEY=
EXA_API_KEY=
TAVILY_API_KEY=
PERPLEXITY_API_KEY=

# Set to 1 to let the Parallel adapter run slower Task API enrichment calls.
# Search works with PARALLEL_API_KEY by default.
CT_SEARCH_LIVE_ENRICHMENT=0

# Claude key for LLM intent parsing (brief -> job type, source shape, evidence
# risk, freshness, returned fields). Without it the router falls back to
# keyword heuristics, so the app still runs.
ANTHROPIC_API_KEY=
# Override the intent model if needed (default claude-opus-4-8).
CT_SEARCH_INTENT_MODEL=claude-opus-4-8
