# Copy to .env.local for local dev (optional — this is the default).
#
# URL of the FastAPI backend that the /backend/* proxy forwards to
# (frontend/next.config.ts). Local dev defaults to the value below. In
# production (Vercel) set this to the Modal deployment URL, e.g.
#   CT_SEARCH_BACKEND_URL=https://<workspace>--edna-search-web.modal.run
CT_SEARCH_BACKEND_URL=http://127.0.0.1:8000
